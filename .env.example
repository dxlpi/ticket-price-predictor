# Ticketmaster API credentials
# Get your API key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_api_key_here

# Spotify API (for artist popularity)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Songkick API (for tracker counts)
SONGKICK_API_KEY=your_songkick_api_key

# Bandsintown API (for tracker counts)
BANDSINTOWN_APP_ID=your_bandsintown_app_id

# Data directory (optional, defaults to ./data)
# DATA_DIR=./data

# Snapshot collection interval in hours (optional, defaults to 6)
# SNAPSHOT_INTERVAL_HOURS=6
